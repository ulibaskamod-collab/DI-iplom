generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ZodiacSign {
  id             Int              @id @default(autoincrement())
  name           String           @unique @db.VarChar(50)
  slug           String           @unique @db.VarChar(50)
  element        String           @db.VarChar(20)
  start_date     String           @db.VarChar(10)
  end_date       String           @db.VarChar(10)
  description    String?
  style_desc     String?
  colors         String[]         @default([])
  image_url      String?
  created_at     DateTime?        @default(now()) @db.Timestamp(6)
  updated_at     DateTime?        @default(now()) @updatedAt @db.Timestamp(6)
  clothing_items ClothingItem[]
  designer_works designer_works[]

  @@map("zodiac_signs")
}

model ClothingItem {
  id             Int         @id @default(autoincrement())
  title          String      @db.VarChar(200)
  description    String?
  image_url      String?
  season         String?     @db.VarChar(20)
  gender         String?     @db.VarChar(20)
  zodiac_sign_id Int?
  created_at     DateTime?   @default(now()) @db.Timestamp(6)
  updated_at     DateTime?   @default(now()) @updatedAt @db.Timestamp(6)
  zodiac_signs   ZodiacSign? @relation(fields: [zodiac_sign_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  favorites      Favorite[]

  @@map("clothing_items")
}

model Favorite {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String       @map("user_id") @db.Uuid
  clothing_item_id Int
  created_at       DateTime?    @default(now()) @db.Timestamp(6)
  clothingItem     ClothingItem @relation(fields: [clothing_item_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user             users        @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, clothing_item_id])
  @@map("favorites")
}

model users {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String?    @db.VarChar(255)
  email       String     @unique @db.VarChar(255)
  password    String?    @db.VarChar(255)
  birth_date  DateTime?  @db.Date
  gender      String?    @db.VarChar(50)
  zodiac_sign String?    @db.VarChar(100)
  user_role   String?    @default("user") @db.VarChar(50)
  created_at  DateTime?  @default(now()) @db.Timestamp(6)
  updated_at  DateTime?  @default(now()) @db.Timestamp(6)
  favorites   Favorite[]
}

model designer_works {
  id             Int         @id @default(autoincrement())
  designer_id    Int
  work_title     String      @db.VarChar(200)
  work_image     String
  description    String?
  zodiac_sign_id Int?
  created_at     DateTime?   @default(now()) @db.Timestamp(6)
  designers      designers   @relation(fields: [designer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  zodiac_signs   ZodiacSign? @relation(fields: [zodiac_sign_id], references: [id], onUpdate: NoAction)
}

model designers {
  id             Int              @id @default(autoincrement())
  designer_name  String           @db.VarChar(100)
  bio            String
  designer_image String
  social_links   Json?            @default("{}")
  created_at     DateTime?        @default(now()) @db.Timestamp(6)
  updated_at     DateTime?        @default(now()) @db.Timestamp(6)
  designer_works designer_works[]
}
